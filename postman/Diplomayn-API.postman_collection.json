    {
      "name": "Auth",
      "description": "Registration, JWT login/refresh, and self-service profile.",
      "item": [
        {
          "name": "Register student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"username\": \"student01\",\n  \"password\": \"secret12\",\n  \"first_name\": \"Anna\",\n  \"last_name\": \"Smith\",\n  \"gender\": \"FEMALE\",\n  \"teacher_ids\": [\n    1\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Creates a new **STUDENT** user, links them to teachers, hashes password, and returns JWTs.\n\n**Body fields**\n- `email` — unique contact email.\n- `username` — unique, 3–30 alphanumeric chars.\n- `password` — min 6 characters (stored hashed).\n- `first_name`, `last_name` — display name.\n- `teacher_ids` — **required** non-empty array of user ids whose `role` is `TICHER`; invalid ids return validation error.\n- `gender` — optional enum: `MALE`, `FEMALE`, or `UNKNOWN`."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    ""
                  ]
                }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
